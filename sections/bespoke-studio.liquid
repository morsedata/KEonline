<style>
  .section-studio { padding: 120px 0; background: var(--surface-alt); }
  .studio { display: grid; grid-template-columns: 1fr 1.1fr; gap: 60px; align-items: center; }
  .studio-visual { aspect-ratio: 1/1; border: 1px solid var(--gold); overflow: hidden; }
  .studio-visual img { width: 100%; height: 100%; object-fit: cover; }
  .studio-copy h2 { font-family: var(--display); font-weight: 600; font-size: clamp(2rem, 3.5vw, 2.8rem); line-height: 1.2; text-transform: uppercase; color: var(--gold); }
  .studio-copy > p { margin-top: 25px; color: var(--muted); line-height: 1.8; max-width: 52ch; font-size: 1rem; font-weight: 300; }
  .studio-actions { display: flex; gap: 15px; margin-top: 30px; flex-wrap: wrap; }
</style>

<section class="section-studio" id="studio">
  <div class="wrap studio">
    <div class="studio-visual">
      <img src="{{ section.settings.studio_image | img_url: 'master' }}" alt="Bespoke tailoring">
    </div>
    <div class="studio-copy">
      <div class="eyebrow">{{ section.settings.eyebrow_text }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body_text }}</p>
      <div class="studio-actions">
        <a href="https://wa.me/{{ section.settings.whatsapp_number | remove: ' ' | remove: '+' }}?text={{ section.settings.whatsapp_message | url_encode }}" target="_blank" rel="noopener" class="btn btn-primary">Enquire via WhatsApp</a>
        <a href="mailto:{{ section.settings.email_address }}" class="btn btn-ghost">Email Enquiry</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bespoke Studio",
  "settings": [
    {
      "type": "image_picker",
      "id": "studio_image",
      "label": "Studio Image"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "Corporate & Exclusive"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Bespoke Studio"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Elevate your corporate narrative. We specialize in crafting bespoke, branded hosiery..."
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number (Include Country Code)",
      "default": "+27768345656"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Default WhatsApp Message",
      "default": "Hello Kingsdale Emporio! I am reaching out from your website..."
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "info@kingsdalesocks.co.za"
    }
  ],
  "presets": [
    {
      "name": "Bespoke Studio"
    }
  ]
}
{% endschema %}
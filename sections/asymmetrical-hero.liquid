{{ 'kingsdale-base.css' | asset_url | stylesheet_tag }}

<style>
  .hero-asymmetrical {
    display: flex; flex-direction: row; min-height: 85vh;
    background-color: var(--bg); overflow: hidden; position: relative;
  }
  .hero-image-side {
    width: 55%; background-size: cover; background-position: left center; position: relative;
  }
  .hero-image-side::after {
    content: ''; position: absolute; top: 0; right: 0; bottom: 0; left: 0;
    background: linear-gradient(to right, transparent 40%, var(--bg) 100%);
  }
  .hero-text-side {
    width: 45%; display: flex; flex-direction: column; justify-content: center;
    padding: 4rem 6% 4rem 0; z-index: 2;
  }
  h1.hero-title {
    font-family: var(--display); font-weight: 700; font-size: clamp(3rem, 6vw, 5.5rem); 
    line-height: 1.1; letter-spacing: 2px; text-transform: uppercase; color: var(--gold);
  }
  .hero-sub { margin-top: 15px; font-family: var(--body); font-weight: 300; font-size: clamp(1rem, 2vw, 1.2rem); letter-spacing: 3px; text-transform: uppercase; color: var(--ink); }
  .hero-copy { margin-top: 30px; color: var(--muted); line-height: 1.8; font-size: 1rem; max-width: 450px; font-weight: 300; }
  .hero-ctas { display: flex; gap: 20px; margin-top: 40px; flex-wrap: wrap; }
</style>

<section class="hero-asymmetrical">
  <div class="hero-image-side" style="background-image: url('{{ section.settings.hero_image | img_url: 'master' }}');"></div>
  <div class="hero-text-side">
    <div class="eyebrow">{{ section.settings.eyebrow_text }}</div>
    <h1 class="hero-title">{{ section.settings.heading }}</h1>
    <p class="hero-sub">{{ section.settings.subheading }}</p>
    <p class="hero-copy">{{ section.settings.body_text }}</p>
    <div class="hero-ctas">
      {% if section.settings.primary_button_link %}
        <a href="{{ section.settings.primary_button_link }}" class="btn btn-primary">{{ section.settings.primary_button_text }}</a>
      {% endif %}
      {% if section.settings.secondary_button_link %}
        <a href="{{ section.settings.secondary_button_link }}" class="btn btn-ghost">{{ section.settings.secondary_button_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Asymmetrical Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image (Subject on left)"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "The Africana Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vibrant Heritage"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curating the Extraordinary"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "We seamlessly blend uncompromising luxury with bold, vibrant geometry."
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Shop Arrivals"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Corporate Gifting"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Asymmetrical Hero"
    }
  ]
}
{% endschema %}